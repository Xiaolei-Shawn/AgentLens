{
  "name": "@xiaolei.shawn/schema",
  "version": "0.2.0",
  "description": "Shared AgentLens schemas and TypeScript contracts for canonical events, trust review, evidence graph, forensic inputs, and session validation.",
  "type": "module",
  "main": "dist/validateSession.js",
  "types": "dist/validateSession.d.ts",
  "exports": {
    ".": {
      "types": "./dist/validateSession.d.ts",
      "import": "./dist/validateSession.js",
      "default": "./dist/validateSession.js"
    },
    "./event-envelope": {
      "types": "./dist/event-envelope.d.ts",
      "import": "./dist/event-envelope.js",
      "default": "./dist/event-envelope.js"
    },
    "./trust-review": {
      "types": "./dist/trust-review.d.ts",
      "import": "./dist/trust-review.js",
      "default": "./dist/trust-review.js"
    },
    "./forensic-inputs": {
      "types": "./dist/forensic-inputs.d.ts",
      "import": "./dist/forensic-inputs.js",
      "default": "./dist/forensic-inputs.js"
    },
    "./evidence-graph": {
      "types": "./dist/evidence-graph.d.ts",
      "import": "./dist/evidence-graph.js",
      "default": "./dist/evidence-graph.js"
    },
    "./session-schema": {
      "types": "./dist/session-schema.d.ts",
      "import": "./dist/session-schema.js",
      "default": "./dist/session-schema.js"
    }
  },
  "files": [
    "dist",
    "*.schema.json",
    "sample-*.json"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc && cp session.schema.json dist/",
    "validate:samples": "node dist/run-validate-samples.js"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Xiaolei-Shawn/AgentLens.git",
    "directory": "schema"
  },
  "bugs": {
    "url": "https://github.com/Xiaolei-Shawn/AgentLens/issues"
  },
  "homepage": "https://github.com/Xiaolei-Shawn/AgentLens/tree/main/schema",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
